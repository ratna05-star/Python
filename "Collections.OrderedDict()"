
from collections import OrderedDict

n = int(input())
ordered_dict = OrderedDict()

for _ in range(n):
    line = input()
    item, _, price = line.rpartition(' ')
    price = int(price)
    if item in ordered_dict:
        ordered_dict[item] += price
    else:
        ordered_dict[item] = price

for item, net_price in ordered_dict.items():
    print(item, net_price)

